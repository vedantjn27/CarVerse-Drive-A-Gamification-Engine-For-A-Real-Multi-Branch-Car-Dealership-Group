# Application
APP_NAME=CarVerse Drive API
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/carverse.db
DATA_DIRECTORY=./data
INGEST_BATCH_SIZE=2000
SCORING_BATCH_SIZE=2000
SQL_ECHO=false
AUTO_RESEED_ON_STARTUP=true
REWORK_DISCOUNT_PERCENT=15
CROSS_DEPT_ASSIST_BUSINESS_HOURS=4
ESCALATION_RESOLUTION_HOURS=24
FAST_DELIVERY_MAX_DAYS=180
BUSINESS_DAY_START_HOUR=9
BUSINESS_DAY_END_HOUR=18
BUSINESS_WORKING_DAYS=0,1,2,3,4,5
MAX_CROSS_DEPT_ASSISTS_PER_BOOKING=6
DAILY_LEADERBOARD_XP_CAP=500
WEEKLY_LEADERBOARD_XP_CAP=2500
DAILY_DELIVERY_LEADERBOARD_CAP=5
LEVEL_XP_BASE=100
LEVEL_XP_EXPONENT=1.5
REPUTATION_CLEAN_WEIGHT=40
REPUTATION_RECOVERY_WEIGHT=25
REPUTATION_QUALITY_WEIGHT=35
STREAK_MILESTONE_BONUSES=3:10,7:25,14:60,30:150

# Authentication (generate a unique value of at least 32 characters)
JWT_SECRET=<generate-a-cryptographically-random-secret>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
JWT_ISSUER=carverse-drive
JWT_AUDIENCE=carverse-frontend

# AI providers (optional; deterministic fallbacks work when both are empty)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_CACHE_TTL_SECONDS=3600
AI_TIMEOUT_SECONDS=12
ANOMALY_Z_THRESHOLD=2.5
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Kolkata
SCHEDULER_NIGHTLY_HOUR=2
SCHEDULER_NIGHTLY_MINUTE=15
SCHEDULER_WEEKLY_DAY=mon

# Frontend and game configuration
CORS_ALLOWED_ORIGINS=*
ACTIVE_DEPARTMENTS=SALES,FINANCE,ACCOUNTS,CUSTOMER CARE,PDI
